{
  "name": "personal-finance-app",
  "private": true,
  "scripts": {
    "api": "pnpm --filter api dev",
    "web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter web lint",
    "db:generate": "pnpm --filter api db:generate",
    "db:push": "pnpm --filter api db:push",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "db:studio": "pnpm --filter api db:studio",
    "db:up": "docker compose -f apps/api/docker-compose.yml up -d",
    "db:down": "docker compose -f apps/api/docker-compose.yml down",
    "start:web": "serve -s apps/web/dist -l ${PORT:-5173}"
  },
  "dependencies": {
    "serve": "^14.2.6"
  }
}
